# Anglerfish reads configuration from the process environment. It does NOT
# auto-load this file — copy it, fill in your values, then `source` it yourself
# (or export the variables directly). All placeholders are quoted so the file
# stays shell-sourceable as-is.

# Required for every workflow:
# ANGLERFISH_TENANT_ID="<your-entra-tenant-id-guid>"
# ANGLERFISH_CLIENT_ID="<your-entra-app-client-id>"

# Credential selection: auto | secret | certificate (default: auto).
ANGLERFISH_APP_CREDENTIAL_MODE="auto"

# Client-secret auth:
# ANGLERFISH_CLIENT_SECRET="<your-app-client-secret>"
# ANGLERFISH_CLIENT_SECRET_FILE="/run/secrets/anglerfish-client-secret"

# Certificate auth (choose PFX or PEM style):
# ANGLERFISH_CLIENT_CERT_PFX_PATH="/absolute/path/client-cert.pfx"
# ANGLERFISH_CLIENT_CERT_PASSPHRASE="<optional-pfx-or-key-passphrase>"
# ANGLERFISH_CLIENT_CERT_PASSPHRASE_FILE="/run/secrets/anglerfish-cert-passphrase"
# ANGLERFISH_CLIENT_CERT_SEND_X5C="true"
# ANGLERFISH_CLIENT_CERT_PRIVATE_KEY_PATH="/absolute/path/client-private-key.pem"
# ANGLERFISH_CLIENT_CERT_PUBLIC_CERT_PATH="/absolute/path/client-public-cert.pem"
# ANGLERFISH_CLIENT_CERT_THUMBPRINT="<hex-thumbprint-no-colons>"

# Grant only the Microsoft Graph / Office 365 Management permissions your
# workflow needs:
# - Outlook draft deploy/cleanup/verify/demo-access: Mail.ReadWrite
# - Outlook send deploy/cleanup:                     Mail.ReadWrite, Mail.Send
# - Monitor / audit polling:                         ActivityFeed.Read

# Optional monitor configuration (CLI flags take precedence):
# ANGLERFISH_MONITOR_STATE_FILE="/path/to/monitor-state.json"   # default: ~/.anglerfish/monitor-state.json
# ANGLERFISH_MONITOR_ALERT_LOG="/path/to/alerts.jsonl"          # JSONL alert log
# ANGLERFISH_SLACK_WEBHOOK_URL="https://hooks.slack.com/services/<your-webhook>"
# ANGLERFISH_MONITOR_NO_CONSOLE="true"                          # suppress console alert output (daemon mode)

# Optional custom template directory (YAML templates, see CONTRIBUTING.md):
# ANGLERFISH_TEMPLATES_DIR="/absolute/path/custom-templates"
