ANGLERFISH_CLIENT_ID=<your-entra-app-client-id>
ANGLERFISH_AUTH_MODE=application
ANGLERFISH_APP_CREDENTIAL_MODE=auto
# Required for application auth mode
# ANGLERFISH_TENANT_ID=<your-entra-tenant-id-guid>
# Required for ANGLERFISH_AUTH_MODE=application
# ANGLERFISH_CLIENT_SECRET=<your-app-client-secret>
# For application mode, ensure Graph app permissions cover your usage:
# - Outlook draft: Mail.ReadWrite
# - Outlook send: Mail.ReadWrite, Mail.Send
# - SharePoint upload: Sites.ReadWrite.All, Files.ReadWrite.All
# Certificate-based application auth (choose PFX or PEM style):
# ANGLERFISH_CLIENT_CERT_PFX_PATH=/absolute/path/client-cert.pfx
# ANGLERFISH_CLIENT_CERT_PASSPHRASE=<optional-pfx-or-key-passphrase>
# ANGLERFISH_CLIENT_CERT_SEND_X5C=true
# ANGLERFISH_CLIENT_CERT_PRIVATE_KEY_PATH=/absolute/path/client-private-key.pem
# ANGLERFISH_CLIENT_CERT_PUBLIC_CERT_PATH=/absolute/path/client-public-cert.pem
# ANGLERFISH_CLIENT_CERT_THUMBPRINT=<hex-thumbprint-no-colons>
